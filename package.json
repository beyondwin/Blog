{
  "name": "url-to-astro-publishing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "sync": "node scripts/sync.mjs",
    "article:new": "node scripts/create-article-packet.mjs",
    "article:quality": "node scripts/article-quality.mjs",
    "memory:seed": "node scripts/memory/seed.mjs",
    "memory:project": "node scripts/memory/project.mjs",
    "memory:validate": "node scripts/memory/project.mjs --validate",
    "validate": "node scripts/validate-content.mjs && npm run article:quality && npm run memory:validate && npm run test && npm run build"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "astro": "latest",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "latest",
    "gray-matter": "^2.0.1",
    "typescript": "latest",
    "vitest": "latest"
  },
  "overrides": {
    "yaml": "^2.9.0"
  }
}
