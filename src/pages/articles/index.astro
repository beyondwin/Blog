---
import ContentCard from '../../components/ContentCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectionMeta, getContentByCollection } from '../../lib/content';

const entries = await getContentByCollection('articles');
const meta = collectionMeta.articles;
---

<BaseLayout title="Articles · beyondwin" description={meta.description}>
  <section class="shell hero">
    <p class="site-label">Development</p>
    <h1>{meta.navLabel}</h1>
    <p>{meta.description}</p>
  </section>
  <section class="shell">
    {entries.length > 0 ? (
      <div class="content-grid">
        {entries.map((entry) => <ContentCard entry={entry} />)}
      </div>
    ) : (
      <div class="empty-state">
        <p>아직 공개된 개발 글이 없습니다.</p>
      </div>
    )}
  </section>
</BaseLayout>
